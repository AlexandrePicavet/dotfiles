[core]
	pager = delta

[commit]
	gpgsign = true

[pull]
	rebase = true
[push]
	autoSetupRemote = true

[diff]
	colorMoved = default
	tool = nvimdiff
	guitool = nvimdiff
[difftool]
	prompt = false
	guiDefault = false
[difftool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$REMOTE\" -c \"wincmd w\" -c \"wincmd L\""

[merge]
	conflictstyle = diff3
	tool = nvimdiff
[mergetool]
	prompt = false
[mergetool "nvimdiff"]
	cmd = "nvim -d \"$LOCAL\" \"$MERGED\" \"$BASE\" \"$REMOTE\" -c \"wincmd w\" -c \"wincmd J\""

[rerere]
	enabled = true

[include]
	path = ~/.config/delta/delta.gitconfig
	path = ~/.user.gitconfig
